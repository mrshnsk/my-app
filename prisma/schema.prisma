datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// 変更後：家計簿支出データに特化したモデル設計
model Expense {
  id        Int      @id @default(autoincrement())
  date      DateTime @default(now())   // 1. 入力：日付
  storeName String                     // 2. 処理：購入した店名
  category  String                     // 3. 表示：食品などの類似カテゴリまとめ用
  details   String                     // 1. 入力：支出の内容
  amount    Int                        // 1. 入力：支出額
}