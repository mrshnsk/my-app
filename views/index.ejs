<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <title>支出一覧</title>
</head>
<body>
  <h1>支出一覧</h1>
  <ul>
  <% users.forEach(user => { %>
    <li><%= user.name %>（<%= user.diff ? user.diff + '円\' : '収支未設定' %>）</li>
  <% }) %>
</ul>
<form action="/users" method="post">
  <input type="text" name="name" placeholder="支出内容" required>
  <input type="number" name="diff" placeholder="収支">
  <button type="submit">追加</button>
</form>



